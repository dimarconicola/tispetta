# Web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_APP=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION_APEX=
NEXT_PUBLIC_GA_MEASUREMENT_ID_APP=
NEXT_PUBLIC_GA_MEASUREMENT_ID_APEX=
SESSION_COOKIE_NAME=boe_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_MAX_AGE_SECONDS=1209600

# API
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000
APP_SECRET_KEY=change-me
APP_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Default local verification can use SQLite if Docker is unavailable:
# DATABASE_URL=sqlite:///./benefits_engine.db
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/benefits_engine
REDIS_URL=redis://localhost:6379/0
AUTO_CREATE_SCHEMA=true
AUTO_SEED_ON_STARTUP=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=false
POSTHOG_API_KEY=
SENTRY_DSN=
OPENAI_API_KEY=

# Shared object storage
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=benefits-engine
OBJECT_STORAGE_REGION=us-east-1

# Worker
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_ENDPOINT_REFRESH_INTERVAL_SECONDS=21600
WORKER_FAMILY_REFRESH_INTERVAL_SECONDS=21600
WORKER_SURVEY_REFRESH_INTERVAL_SECONDS=86400
SNAPSHOT_STORAGE_BACKEND=local
SNAPSHOT_DIR=./tmp/snapshots
