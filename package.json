{
  "name": "benefits-opportunity-engine",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "concurrently -n web,api,worker -c blue,green,yellow \"pnpm --filter web dev\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "cd services/api && python3 -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:worker": "cd services/worker && PYTHONPATH=../api python3 -m worker.main",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm --filter web typecheck",
    "test": "pnpm --filter web test && cd services/api && DATABASE_URL=sqlite:///./benefits_engine.db python3 -m pytest",
    "test:e2e:critical": "python3 qa/scripts/run_critical_e2e.py",
    "qa:data:integrity": "python3 qa/scripts/check_data_integrity.py --reseed",
    "qa:data:freshness": "python3 qa/scripts/check_data_freshness.py --reseed",
    "qa:data:links": "python3 qa/scripts/check_link_health.py --reseed --sample-size 25",
    "test:pr-gate": "./qa/scripts/run_pr_gate.zsh",
    "test:release-gate": "./qa/scripts/run_release_gate.zsh",
    "test:nightly-data": "./qa/scripts/run_nightly_data.zsh",
    "seed": "cd services/api && PYTHONPATH=. python3 -m app.seeds.cli",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7"
  }
}
